<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="parkingPU" transaction-type="JTA">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <jta-data-source>java:jboss/datasources/ParkingDS</jta-data-source>
        <class>it.unifi.swam.parking.model.User</class>
        <class>it.unifi.swam.parking.model.Vehicle</class>
        <class>it.unifi.swam.parking.model.ParkingPass</class>
        <class>it.unifi.swam.parking.model.Violation</class>
        <class>it.unifi.swam.parking.model.VehicleType</class>
        <class>it.unifi.swam.parking.model.EngineType</class>
        <class>it.unifi.swam.parking.model.District</class>
        <class>it.unifi.swam.parking.model.ParkingZone</class>
        
        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
